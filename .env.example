# Database
DATABASE_URL=postgresql://threaddash:password@localhost:5432/threaddash_dev
REDIS_URL=redis://localhost:6380  # host port remapped from 6379 (conflict with another project)

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Ports (each service)
API_GATEWAY_PORT=3000
ORDER_SERVICE_PORT=3001
WAREHOUSE_SERVICE_PORT=3002
ROUTING_SERVICE_PORT=8000
NOTIFICATION_SERVICE_PORT=3003
PAYMENT_SERVICE_PORT=3004
REALTIME_SERVICE_PORT=3005

# Razorpay
RAZORPAY_KEY_ID=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET=REPLACE_ME

# Firebase (FCM)
FIREBASE_PROJECT_ID=threaddash-dev
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@threaddash-dev.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nREPLACE_ME\n-----END PRIVATE KEY-----"

# Twilio (SMS fallback)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Routing
OSRM_BASE_URL=http://localhost:5000
GOOGLE_MAPS_API_KEY=REPLACE_ME

# Maps
MAPBOX_PUBLIC_TOKEN=pk.REPLACE_ME

# AWS S3 (media/CDN)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=threaddash-media
AWS_ACCESS_KEY_ID=REPLACE_ME
AWS_SECRET_ACCESS_KEY=REPLACE_ME
CLOUDFRONT_DOMAIN=https://cdn.threaddash.in

# Admin Dashboard
ADMIN_SECRET=REPLACE_ME

# App Config
NODE_ENV=development
LOG_LEVEL=debug
MAX_CONCURRENT_DELIVERIES=3
WAREHOUSE_SELECTION_RADIUS_KM=10
AGENT_SELECTION_RADIUS_KM=8
TRIAL_WINDOW_MINUTES=30
MAX_TRIAL_EXTENSION_MINUTES=15
MAX_TRY_ORDER_ITEMS=5
CANCELLATION_FEE_PAISE=9900
COD_CONVENIENCE_FEE_PAISE=2000
