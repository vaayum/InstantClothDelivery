// ThreadDash — PostgreSQL + PostGIS schema
// Run: npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  AGENT
  WAREHOUSE_STAFF
  ADMIN
}

enum AgentStatus {
  AVAILABLE
  EN_ROUTE_WAREHOUSE
  EN_ROUTE_CUSTOMER
  BUSY
  OFF_DUTY
}

enum WarehouseStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum OrderStatus {
  PENDING
  WAREHOUSE_PROCESSING
  READY_FOR_PICKUP
  AGENT_ASSIGNED
  AGENT_EN_ROUTE
  ARRIVED
  TRIAL_IN_PROGRESS
  COMPLETED
  DELIVERED
  PARTIALLY_DELIVERED
  RETURNED
  CANCELLED
  RESCHEDULED
}

enum OrderItemStatus {
  PENDING
  KEPT
  RETURNED
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  PICKED_UP
  DELIVERED
  DECLINED
  ABSENT
  RESCHEDULED
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  COD
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

enum ReturnCondition {
  GOOD
  DAMAGED
  TAGS_MISSING
}

enum PickingStatus {
  PENDING
  IN_PROGRESS
  PACKED
}

enum PickItemStatus {
  PENDING
  FOUND
  NOT_AVAILABLE
}

enum NotificationType {
  ORDER_CONFIRMED
  WAREHOUSE_PROCESSING
  AGENT_ASSIGNED
  AGENT_NEARBY
  AGENT_ARRIVED
  TRIAL_WARNING
  ORDER_COMPLETE
  RESCHEDULE_PROMPT
  RETURN_PICKUP_SCHEDULED
  NEW_ASSIGNMENT
  SLA_WARNING
  SLA_BREACH
  LOW_STOCK
  RETURN_ARRIVED
}

// ─── Users & Auth ─────────────────────────────────────────────────────────────

model User {
  id                String     @id @default(uuid())
  phone             String     @unique
  email             String?    @unique
  name              String
  role              UserRole   @default(CUSTOMER)
  sizeProfile       Json?
  stylePrefs        Json?
  isActive          Boolean    @default(true)
  fcmToken          String?
  pinnedWarehouseId String?
  pinnedEtaMinutes  Int?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  addresses       Address[]
  orders          Order[]
  notifications   Notification[]
  subscription    Subscription?
  wishlist        Wishlist[]
  pinnedWarehouse Warehouse? @relation("UserPinnedWarehouse", fields: [pinnedWarehouseId], references: [id])

  @@map("users")
}

model Address {
  id               String   @id @default(uuid())
  userId           String
  label            String
  formattedAddress String
  lat              Float
  lng              Float
  isSafeDrop       Boolean  @default(false)
  safeDropNote     String?
  createdAt        DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]

  @@map("addresses")
}

// ─── Zones & Warehouses ───────────────────────────────────────────────────────

model Zone {
  id        String  @id @default(uuid())
  name      String
  centerLat Float
  centerLng Float
  radiusKm  Float   @default(5.0)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())

  warehouses Warehouse[]

  @@map("zones")
}

model Warehouse {
  id               String          @id @default(uuid())
  name             String
  zoneId           String
  lat              Float
  lng              Float
  address          String
  capacitySqFt     Int
  status           WarehouseStatus @default(ACTIVE)
  activeOrderCount Int             @default(0)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  zone          Zone          @relation(fields: [zoneId], references: [id])
  inventory     Inventory[]
  orders        Order[]
  pickingTasks  PickingTask[]
  pinnedByUsers User[]        @relation("UserPinnedWarehouse")

  @@map("warehouses")
}

// ─── Catalog ──────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(uuid())
  name        String
  brand       String
  category    String
  gender      String   @default("Unisex")
  description String?
  price       Int
  images      Json
  isActive    Boolean  @default(true)
  isTryable   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skus      Sku[]
  wishlists Wishlist[]

  @@map("products")
}

model Sku {
  id        String   @id @default(uuid())
  productId String
  size      String
  color     String
  barcode   String   @unique
  createdAt DateTime @default(now())

  product      Product       @relation(fields: [productId], references: [id])
  inventory    Inventory[]
  orderItems   OrderItem[]
  pickingItems PickingItem[]

  @@map("skus")
}

model Inventory {
  id                String   @id @default(uuid())
  skuId             String
  warehouseId       String
  quantityAvailable Int      @default(0)
  quantityReserved  Int      @default(0)
  reorderThreshold  Int      @default(3)
  updatedAt         DateTime @updatedAt

  sku       Sku       @relation(fields: [skuId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([skuId, warehouseId])
  @@map("inventory")
}

// ─── Orders ───────────────────────────────────────────────────────────────────

model Order {
  id              String        @id @default(uuid())
  userId          String
  addressId       String
  warehouseId     String
  status          OrderStatus   @default(PENDING)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)
  razorpayOrderId String?
  totalAmount     Int
  deliveryFee     Int           @default(0)
  isTryOrder      Boolean       @default(false)
  trialStartedAt  DateTime?
  trialEndsAt     DateTime?
  slaBreach       Boolean       @default(false)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user        User                @relation(fields: [userId], references: [id])
  address     Address             @relation(fields: [addressId], references: [id])
  warehouse   Warehouse           @relation(fields: [warehouseId], references: [id])
  items       OrderItem[]
  assignment  DeliveryAssignment?
  returns     Return[]
  pickingTask PickingTask?

  @@map("orders")
}

model OrderItem {
  id       String          @id @default(uuid())
  orderId  String
  skuId    String
  quantity Int             @default(1)
  price    Int
  status   OrderItemStatus @default(PENDING)

  order  Order   @relation(fields: [orderId], references: [id])
  sku    Sku     @relation(fields: [skuId], references: [id])
  return Return?

  @@map("order_items")
}

// ─── Agents & Assignments ─────────────────────────────────────────────────────

model Agent {
  id               String      @id @default(uuid())
  userId           String      @unique
  status           AgentStatus @default(OFF_DUTY)
  currentLat       Float?
  currentLng       Float?
  lastUpdatedAt    DateTime?
  vehicleType      String      @default("two_wheeler")
  maxConcurrent    Int         @default(3)
  rating           Float       @default(5.0)
  totalDeliveries  Int         @default(0)
  createdAt        DateTime    @default(now())

  assignments DeliveryAssignment[]

  @@map("agents")
}

model DeliveryAssignment {
  id             String           @id @default(uuid())
  orderId        String           @unique
  agentId        String
  status         AssignmentStatus @default(ASSIGNED)
  assignedAt     DateTime         @default(now())
  acceptedAt     DateTime?
  pickedUpAt     DateTime?
  arrivedAt      DateTime?
  deliveredAt    DateTime?
  absentAttempts Int              @default(0)
  notes          String?

  order Order @relation(fields: [orderId], references: [id])
  agent Agent @relation(fields: [agentId], references: [id])

  @@map("delivery_assignments")
}

// ─── Returns ──────────────────────────────────────────────────────────────────

model Return {
  id           String          @id @default(uuid())
  orderId      String
  orderItemId  String          @unique
  condition    ReturnCondition @default(GOOD)
  reason       String?
  photoUrl     String?
  refundAmount Int
  refundedAt   DateTime?
  processedAt  DateTime?
  createdAt    DateTime        @default(now())

  order     Order     @relation(fields: [orderId], references: [id])
  orderItem OrderItem @relation(fields: [orderItemId], references: [id])

  @@map("returns")
}

// ─── Picking ──────────────────────────────────────────────────────────────────

model PickingTask {
  id          String        @id @default(uuid())
  orderId     String        @unique
  warehouseId String
  status      PickingStatus @default(PENDING)
  slaDeadline DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order     Order         @relation(fields: [orderId], references: [id])
  warehouse Warehouse     @relation(fields: [warehouseId], references: [id])
  items     PickingItem[]

  @@map("picking_tasks")
}

model PickingItem {
  id            String         @id @default(uuid())
  pickingTaskId String
  skuId         String
  quantity      Int
  status        PickItemStatus @default(PENDING)
  scannedAt     DateTime?

  pickingTask PickingTask @relation(fields: [pickingTaskId], references: [id])
  sku         Sku         @relation(fields: [skuId], references: [id])

  @@map("picking_items")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  data        Json?
  sentAt      DateTime         @default(now())
  readAt      DateTime?
  smsFallback Boolean          @default(false)

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ─── Subscriptions (ThreadPass) ───────────────────────────────────────────────

model Subscription {
  id            String   @id @default(uuid())
  userId        String   @unique
  plan          String
  startsAt      DateTime
  expiresAt     DateTime
  isActive      Boolean  @default(true)
  razorpaySubId String?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("subscriptions")
}

// ─── Wishlist ──────────────────────────────────────────────────────────────────

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
  @@map("wishlists")
}
